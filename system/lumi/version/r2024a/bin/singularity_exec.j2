#!/bin/bash

# Exec matlab container
singularity --silent exec \
    --bind="/run/user" \
    --bind="/pfs,/users,/projappl,/scratch,/project,$TMPDIR,$LOCAL_SCRATCH" \
    --bind="/appl/local/csc/soft/math/mathworksservicehost" \
    --env="MATHWORKS_SERVICE_HOST_MANAGED_INSTALL_ROOT=/appl/local/csc/soft/math/mathworksservicehost" \
    "/appl/local/csc/soft/math/matlab/{{ version }}/matlab.sif" "$@"
