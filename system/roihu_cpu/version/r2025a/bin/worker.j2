#!/bin/bash

# Increase virtual memory to the hard limit (required on login nodes).
ulimit -v "$(ulimit -Hv)"

# Print directory if it exists
#ifexists() { [ -d "$1" ] && echo "$1"; }

# MATLAB license. Defaults to CSC license.
: "${MLM_LICENSE_FILE:="1766@license4.csc.fi"}"
export MLM_LICENSE_FILE

# Path to image file. Defaults to CSC image.
: "${MATLAB_SIF_IMAGE:="{{ appl_dir }}/matlab/{{ version }}/matlab.sif"}"

# Call matlab with the right arguments
apptainer --silent exec \
    --bind="/run/user" \
    --bind="/users,/projappl,/scratch,$TMPDIR,$LOCAL_SCRATCH" \
    "${MATLAB_SIF_IMAGE}" worker "$@"
